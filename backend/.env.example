GEMINI_API_KEY=your_gemini_api_key_here
PORT=3000

# Postgres connection string (cloud database for accounts).
# Get this free from Neon (neon.tech) or Supabase (supabase.com) —
# both give you a ready-to-paste connection string on their dashboard.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Long, random secret used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# Optional: only needed for the forgot-password email to actually send.
# If left blank, reset codes are printed to the server console instead
# (fine for development, not for real users).
# For Gmail: use an "App Password", not your normal password —
# https://support.google.com/accounts/answer/185833
EMAIL_USER=
EMAIL_PASS=
